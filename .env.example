# Poker App Configuration
# Copy this to .env and edit as needed

# Public URL of your server (leave empty if using same domain/port)
# Example: https://poker.yourdomain.com
VITE_SERVER_URL=

# How many hours before an inactive lobby is cleaned up (default: 24)
LOBBY_TIMEOUT_HOURS=24

# Maximum number of concurrent lobbies (default: 5)
MAX_LOBBIES=5
